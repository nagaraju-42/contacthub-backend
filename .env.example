

# PostgreSQL Database URL (Required for production)
DATABASE_URL=jdbc:postgresql://your-db-host:5432/your-db-name?sslmode=require
DB_USER=your_db_user
DB_PASS=your_db_password

# Cloudinary (for image uploads)
CLOUDINARY_URL=cloudinary://your-key:your-secret@your-cloud

# JWT Secret (Generate a strong random string, min 32 characters)
JWT_SECRET=your-super-secret-jwt-key-at-least-32-characters-long

# Frontend URL (for CORS)
FRONTEND_URL=https://your-frontend-domain.com

# Optional: Rendering port (auto-set by Render)
# PORT=8080
JWT_SECRET=5681bd37-0d5c-4041-8592-a53f01f087cb

# Frontend URL
FRONTEND_URL=http://localhost:3000
